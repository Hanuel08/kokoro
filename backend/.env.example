# Backend Configuration
# Copy this file to .env and fill in your values

# OpenRouter API keys (get yours at https://openrouter.ai/keys)
KOKORO_ANSWERS_API_KEY=sk-or-v1-your-key-here
KOKORO_EMOTIONS_API_KEY=sk-or-v1-your-key-here

# AI Models (optional, defaults below)
# MODEL_AI_ANSWERS=openai/gpt-oss-120b:free
# MODEL_AI_EMOTIONS=google/gemma-4-31b-it:free

# Unreal Speech API key (get yours at https://unrealspeech.com/)
UNREAL_API_KEY=your-unreal-speech-key-here

# Server
# PORT=4000
# CORS_ORIGIN=http://localhost:5173
